# Personal/site content (name, bio, contact info, job history, projects) is NOT
# configured via environment variables. See content/*.example.json and the
# "Content setup" section of README.md.

NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Only needed if you point the content loader somewhere other than ./content
# CONTENT_DIR=./content

# Required for the contact form to actually send email (via Resend, resend.com).
# Real value goes in .env.local (gitignored) or your host's env — never commit it.
# RESEND_API_KEY=re_your_api_key_here

# Optional: the "from" address Resend sends as. Defaults to Resend's shared
# sandbox sender (onboarding@resend.dev), which works without verifying your
# own domain but is less deliverable/trustworthy long-term.
# RESEND_FROM_EMAIL=contact@yourdomain.com

# Optional: where contact-form submissions are DELIVERED. Defaults to the
# email displayed on the site (content/contact.json). Resend's sandbox sender
# only delivers to your Resend account's own address — set this to that
# address until you verify a domain, or whenever the display address and the
# real inbox differ.
# RESEND_TO_EMAIL=you@example.com

# Optional: enables the private plain-text resume at /api/resume. Comma-
# separated secret tokens — hand each recruiter their own so links can be
# revoked individually. Unset/empty = endpoint stays a 404 for everyone.
# Fetch with: curl "https://yourdomain.com/api/resume?key=TOKEN"
#         or: curl -H "Authorization: Bearer TOKEN" https://yourdomain.com/api/resume
# Generate tokens with: openssl rand -hex 24
# RESUME_ACCESS_TOKENS=token-for-recruiter-a,token-for-recruiter-b

# Required in production for nginx + Let's Encrypt (see DEPLOY.md and
# nginx/init-letsencrypt.sh). Not used in local dev.
# DOMAIN=yourdomain.com

# Optional: contact address Let's Encrypt uses for expiry/security notices.
# LETSENCRYPT_EMAIL=you@yourdomain.com
