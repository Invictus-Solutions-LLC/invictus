# Personal/site content (name, bio, contact info, job history, projects) is NOT
# configured via environment variables. See content/*.example.json and the
# "Content setup" section of README.md.

NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Only needed if you point the content loader somewhere other than ./content
# CONTENT_DIR=./content

# Required for the contact form to actually send email (via Resend, resend.com).
# Real value goes in .env.local (gitignored) or your host's env — never commit it.
# RESEND_API_KEY=re_your_api_key_here

# Optional: the "from" address Resend sends as. Defaults to Resend's shared
# sandbox sender (onboarding@resend.dev), which works without verifying your
# own domain but is less deliverable/trustworthy long-term.
# RESEND_FROM_EMAIL=contact@yourdomain.com
