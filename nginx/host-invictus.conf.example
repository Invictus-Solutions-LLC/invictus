# Example server block for running invictus behind your OWN host nginx.
#
# The app container (docker-compose.app.yml) listens on 127.0.0.1:3000; this
# proxies your domain to it. Replace invictus808.com with your domain.
#
# Install:
#   sudo cp nginx/host-invictus.conf.example /etc/nginx/conf.d/invictus808.com.conf
#   # (edit server_name), then validate + reload:
#   sudo nginx -t && sudo systemctl reload nginx
#   # add HTTPS (:443 block + HTTP->HTTPS redirect) automatically:
#   sudo certbot --nginx -d invictus808.com -d www.invictus808.com
#
# The app already sends its own security headers AND Content-Security-Policy,
# which pass straight through this proxy — do NOT re-add them here or you'll get
# duplicates. The one header the app does not set is HSTS; after certbot creates
# the :443 server block, add this line inside it:
#
#   add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;

server {
    listen 80;
    listen [::]:80;
    server_name invictus808.com www.invictus808.com;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
